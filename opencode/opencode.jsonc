{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,

  // DCP (Dynamic Context Pruning): surgical mid-session context management.
  // Configured via dcp.jsonc. Prefer this over OpenCode's built-in compaction.
  "plugin": ["@tarquinen/opencode-dcp", "./enforce.ts"],

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (mini)",
      "options": {
        "baseURL": "http://mini:11434/v1",
      },
      "models": {
        "qwen2.5:14b": { "name": "Qwen 2.5 14B" },
        "qwen2.5-coder:14b": { "name": "Qwen 2.5 Coder 14B" },
        "qwen3:14b": { "name": "Qwen 3 14B" },
        "gemma3:12b": { "name": "Gemma 3 12B" },
      },
    },
  },

  "permission": {
    "external_directory": {
      "~/.worktrees/**": "allow",
      "~/.ssh/config": "allow",
      "/tmp/**": "allow",
    },
    "bash": {
      "*": "ask",

      "snip git status*": "allow",
      "snip git diff*": "allow",
      "snip git log*": "allow",
      "snip git show*": "allow",
      "snip git branch --show-current": "allow",
      "snip git worktree list*": "allow",

      "snip gh auth status*": "allow",
      "snip gh pr list*": "allow",
      "snip gh pr view*": "allow",
      "snip gh pr checks*": "allow",
      "snip gh pr diff*": "allow",
      "snip gh run list*": "allow",
      "snip gh run view*": "allow",

      "snip task --list*": "allow",
      "snip kubectl get *": "allow",
      "snip kubectl diff *": "allow",
      "snip helmfile * template *": "allow",
    },
  },
}
