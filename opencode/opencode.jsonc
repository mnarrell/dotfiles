{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,

  // DCP (Dynamic Context Pruning): surgical mid-session context management.
  // Configured via dcp.jsonc. Prefer this over OpenCode's built-in compaction.
  "plugin": ["@tarquinen/opencode-dcp", "./enforce.ts"],

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (mini)",
      "options": {
        "baseURL": "http://mini:11434/v1",
      },
      "models": {
        "qwen2.5:14b": { "name": "Qwen 2.5 14B" },
        "qwen2.5-coder:14b": { "name": "Qwen 2.5 Coder 14B" },
        "qwen3:14b": { "name": "Qwen 3 14B" },
        "gemma3:12b": { "name": "Gemma 3 12B" },
      },
    },
  },

  "permission": {
    "external_directory": {
      "~/.worktrees/**": "allow",
      "~/.ssh/config": "allow",
      "/tmp/**": "allow",
    },
    "bash": {
      "*": "ask",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch --show-current": "allow",
      "git worktree list*": "allow",

      "snip git status*": "allow",
      "snip git diff*": "allow",
      "snip git log*": "allow",
      "snip git show*": "allow",
      "snip git branch --show-current": "allow",
      "snip git worktree list*": "allow",

      "gh auth status*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",

      "task --list*": "allow",
      "kubectl get *": "allow",
      "kubectl diff *": "allow",
      "helmfile * template *": "allow",

      "git *": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git merge * main": "ask",
      "git merge * --into main": "ask",
      "git reset *": "ask",
      "git restore *": "ask",
      "git checkout -- *": "ask",
      "git clean *": "ask",
      "git branch -D *": "ask",
      "git worktree remove *": "ask",

      "gh pr create *": "ask",
      "gh pr merge * --base main": "ask",
      "kubectl apply *": "ask",
      "task *:apply*": "ask",
      "task infra:*": "ask",
      "task flux:bootstrap": "ask",
      "tofu *": "ask",
    },
  },
}
